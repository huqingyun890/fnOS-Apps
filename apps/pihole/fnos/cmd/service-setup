#!/bin/bash

service_postinst() {
    local env_file="${TRIM_APPDEST}/docker/.env"
    local need_env=false

    mkdir -p "${TRIM_PKGVAR}/etc-pihole" "${TRIM_PKGVAR}/etc-dnsmasq.d" 2>/dev/null || true

    : > "$env_file"
    if [ -n "${wizard_password}" ]; then
        echo "PIHOLE_PASSWORD=${wizard_password}" >> "$env_file"
        need_env=true
    fi

    if [ "$need_env" = true ]; then
        chmod 600 "$env_file"
        install_log "Wrote docker .env with wizard values"
    else
        rm -f "$env_file"
    fi
}

COMPOSE_FILE="${TRIM_APPDEST}/docker/docker-compose.yaml"
PORT_SAVE="${TRIM_PKGVAR}/.port"

apply_port() {
    local port="$1"
    [ -z "$port" ] && return
    sed -i 's/"[^"]*:80"/"'"${port}"':80"/' "$COMPOSE_FILE"
    echo "${port}" > "$PORT_SAVE"
    install_log "Patched docker-compose.yaml: port=${port}"
}

service_postupgrade() {
    if [ -f "$PORT_SAVE" ]; then
        apply_port "$(cat "$PORT_SAVE")"
    fi
}

service_postconfig() {
    if [ -n "${wizard_port:-}" ]; then
        apply_port "${wizard_port}"
    fi
}
